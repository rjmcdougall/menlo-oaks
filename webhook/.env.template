# Environment Configuration Template for UniFi Protect License Plate Detection
# Copy this file to .env.development, .env.production, etc. and fill in your values

# Required: Google Cloud Project ID
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery Configuration (optional, will use defaults if not set)
BIGQUERY_DATASET=license_plates
BIGQUERY_TABLE=detections
BIGQUERY_LOCATION=US

# UniFi Protect Configuration (required for full functionality)
UNIFI_PROTECT_HOST=your.unifi.protect.host
UNIFI_PROTECT_PORT=443
UNIFI_PROTECT_USERNAME=your-username
UNIFI_PROTECT_PASSWORD=your-password
UNIFI_PROTECT_VERIFY_SSL=true

# Webhook Security (recommended)
WEBHOOK_SECRET=your-webhook-secret-key

# Processing Configuration
MIN_CONFIDENCE_THRESHOLD=0.7
STORE_IMAGES=false
GCS_BUCKET_NAME=your-gcs-bucket-name

# Logging
LOG_LEVEL=INFO

# Environment Type (development, production, test)
ENVIRONMENT=development
